  "extends": ["config:recommended", ":dependencyDashboard"],
  "kubernetes": {
    "fileMatch": ["(^|/)deployment\\.yaml$"]
  },
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "pinDigests": true,
      "automerge": false
    }
  ]
}