{
  "name": "Kubernetes",
  "build":{
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "containerEnv": {
    "GPG_TTY": "/dev/tty"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "opentofu.vscode-opentofu",
        "redhat.vscode-yaml",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "redhat.ansible"
      ],
      "settings":{
        "git.enableCommitSigning": true,
        "git.commitSigningOffloading": true

      }
    }
  },
  "postCreateCommand": "",
  "remoteUser": "vscode",
  "features": {},
  "forwardPorts": [],
  "mounts": [],
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}"
}
